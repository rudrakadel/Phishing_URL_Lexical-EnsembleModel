APP_ENV=production
APP_ROLE=web
FLASK_DEBUG=0
FLASK_SECRET_KEY=replace-with-a-long-random-secret
APP_REQUIRE_AUTH=1
APP_USERNAME=admin
APP_PASSWORD_HASH=pbkdf2:sha256:600000$replace$replace
DATABASE_URL=postgresql://phishscope:phishscope@db:5432/phishscope
REDIS_URL=redis://redis:6379/0
METRICS_TOKEN=replace-with-a-random-token
GOOGLE_CLIENT_ID=
VT_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=deepseek:1.5b
RATE_LIMIT_ANALYZE_PER_WINDOW=30
RATE_LIMIT_BATCH_PER_WINDOW=5
RATE_LIMIT_LOGIN_PER_WINDOW=10
RATE_LIMIT_NOTES_PER_WINDOW=30
RATE_LIMIT_WINDOW_SECONDS=60
BATCH_MAX_URLS=50
ENABLE_BACKGROUND_WORKER=1
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_RETRIES=5
WORKER_STALE_AFTER_SECONDS=300
REQUEST_TIMEOUT_SECONDS=5
EXTERNAL_TIMEOUT_SECONDS=4
OLLAMA_TIMEOUT_SECONDS=18
SCREENSHOT_TIMEOUT_MS=15000
